# Application Settings
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://127.0.0.1:3000","capacitor://localhost","ionic://localhost"]

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/language_learning

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PRIMARY_LLM_PROVIDER=openai
SECONDARY_LLM_PROVIDER=anthropic
OPENAI_MODEL=gpt-5-mini
OPENAI_ERROR_DETECTION_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT_SECONDS=240
# Production serial Feuilleton requires OPENAI_API_KEY plus these story models.
# If SERIAL_WORLD_ENABLED=true without a story LLM, episode 1+ scenes return a delayed edition instead of replaying the pilot.
OPENAI_GRAPHIC_NOVEL_SCRIPT_MODEL=gpt-5.4-mini
OPENAI_GRAPHIC_NOVEL_PREMIUM_SCRIPT_MODEL=gpt-5.5
GRAPHIC_NOVEL_DEFAULT_PANEL_COUNT=6
GRAPHIC_NOVEL_IMAGE_COST_USD_PER_PANEL=0.053
GRAPHIC_NOVEL_IMAGE_CONCURRENCY=3
GRAPHIC_NOVEL_IMAGE_GENERATION_ENABLED=false
SERIAL_WORLD_ENABLED=true
SERIAL_PHONE_CALL_MISSIONS_ENABLED=false
# Optional overrides for self-hosted compatible gateways:
# OPENAI_API_BASE=https://your-openai-compatible-endpoint/v1
ANTHROPIC_MODEL=claude-3-5-sonnet
# ANTHROPIC_API_BASE=https://your-anthropic-compatible-endpoint
PERPLEXITY_API_KEY=
SUBSTACK_FEED_URLS=
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
FRENCH_NLP_MODEL=fr_core_news_sm
ATELIER_LLM_ENABLED=true

# Dev convenience (auto-create users on login if they don't exist)
AUTO_CREATE_USERS_ON_LOGIN=true

# Session Capacity Settings
DEFAULT_MINUTES_PER_TURN=3.0
MIN_WORDS_PER_TURN=4
MAX_WORDS_PER_TURN=8

# SRS Performance Settings
REVIEW_PERFORMANCE_LOOKBACK_DAYS=7
POOR_PERFORMANCE_THRESHOLD=0.5
GOOD_PERFORMANCE_THRESHOLD=0.7

# Daily Limits
MAX_NEW_WORDS_PERCENTAGE=0.5
